# Database (copy to .env and update credentials)
DATABASE_URL=postgresql://artifactforge:<your-password>@localhost:5432/artifactforge

# LLM Providers (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Web Search
TAVILY_API_KEY=

# Additional Research APIs (optional)
PERPLEXITY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Context7 - Optional (higher rate limits with API key)
CONTEXT7_API_KEY=

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
